# ── Mercado Pago ──────────────────────────────────────────
# Obtén tu token en: mercadopago.com.mx/developers/panel
# Usa TEST-... para pruebas, y el token de producción cuando estés lista
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx

# ── Google Sheets ─────────────────────────────────────────
# ID del Sheet (entre /d/ y /edit en la URL del Sheet)
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Del archivo .json descargado al crear la cuenta de servicio en Google Cloud
GOOGLE_SERVICE_ACCOUNT_EMAIL=nail-booking@nail-studio-booking.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n

# ── Alertas por email (Resend) ────────────────────────────
# Crea cuenta gratis en resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email donde quieres recibir alertas de reagendas y cancelaciones
OWNER_EMAIL=tuemail@gmail.com
